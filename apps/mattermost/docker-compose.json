{
  "services": [
    {
      "name": "postgres",
      "image": "postgres:15-alpine",
      "environment": [
        {
          "key": "POSTGRES_USER",
          "value": "mattermost"
        },
        {
          "key": "POSTGRES_PASSWORD",
          "value": "${DB_PASSWORD}"
        },
        {
          "key": "POSTGRES_DB",
          "value": "mattermost"
        }
      ],
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/postgres",
          "containerPath": "/var/lib/postgresql/data"
        }
      ],
      "healthCheck": {
        "test": "pg_isready -U mattermost -d mattermost",
        "interval": "5s",
        "timeout": "5s",
        "retries": 5
      }
    },
    {
      "name": "mattermost",
      "image": "mattermost/mattermost-team-edition:9.8.0",
      "isMain": true,
      "dependsOn": ["postgres"],
      "environment": [
        {
          "key": "MM_SQLSETTINGS_DRIVERNAME",
          "value": "postgres"
        },
        {
          "key": "MM_SQLSETTINGS_DATASOURCE",
          "value": "postgres://mattermost:${DB_PASSWORD}@postgres:5432/mattermost?sslmode=disable&connect_timeout=10"
        },
        {
          "key": "MM_SERVICESETTINGS_SITEURL",
          "value": "https://${APP_DOMAIN}"
        },
        {
          "key": "MM_SERVICESETTINGS_LISTENADDRESS",
          "value": ":8065"
        },
        {
          "key": "MM_FILESETTINGS_DIRECTORY",
          "value": "/mattermost/data"
        },
        {
          "key": "MM_LOGSETTINGS_FILELOCATION",
          "value": "/mattermost/logs"
        }
      ],
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data",
          "containerPath": "/mattermost/data"
        },
        {
          "hostPath": "${APP_DATA_DIR}/logs",
          "containerPath": "/mattermost/logs"
        },
        {
          "hostPath": "${APP_DATA_DIR}/config",
          "containerPath": "/mattermost/config"
        },
        {
          "hostPath": "${APP_DATA_DIR}/plugins",
          "containerPath": "/mattermost/plugins"
        },
        {
          "hostPath": "${APP_DATA_DIR}/client_plugins",
          "containerPath": "/mattermost/client/plugins"
        }
      ],
      "extraLabels": {
        "traefik.enable": "true",
        "traefik.http.middlewares.{{RUNTIPI_APP_ID}}-web-redirect.redirectscheme.scheme": "https",
        "traefik.http.services.{{RUNTIPI_APP_ID}}.loadbalancer.server.port": "8065",
        "traefik.http.routers.{{RUNTIPI_APP_ID}}-insecure.rule": "Host(`${APP_DOMAIN}`)",
        "traefik.http.routers.{{RUNTIPI_APP_ID}}-insecure.entrypoints": "web",
        "traefik.http.routers.{{RUNTIPI_APP_ID}}-insecure.service": "{{RUNTIPI_APP_ID}}",
        "traefik.http.routers.{{RUNTIPI_APP_ID}}-insecure.middlewares": "{{RUNTIPI_APP_ID}}-web-redirect",
        "traefik.http.routers.{{RUNTIPI_APP_ID}}.rule": "Host(`${APP_DOMAIN}`)",
        "traefik.http.routers.{{RUNTIPI_APP_ID}}.entrypoints": "websecure",
        "traefik.http.routers.{{RUNTIPI_APP_ID}}.service": "{{RUNTIPI_APP_ID}}",
        "traefik.http.routers.{{RUNTIPI_APP_ID}}.tls.certresolver": "myresolver",
        "traefik.http.routers.{{RUNTIPI_APP_ID}}-local-insecure.rule": "Host(`{{RUNTIPI_APP_ID}}.${LOCAL_DOMAIN}`)",
        "traefik.http.routers.{{RUNTIPI_APP_ID}}-local-insecure.entrypoints": "web",
        "traefik.http.routers.{{RUNTIPI_APP_ID}}-local-insecure.service": "{{RUNTIPI_APP_ID}}",
        "traefik.http.routers.{{RUNTIPI_APP_ID}}-local-insecure.middlewares": "{{RUNTIPI_APP_ID}}-web-redirect",
        "traefik.http.routers.{{RUNTIPI_APP_ID}}-local.rule": "Host(`{{RUNTIPI_APP_ID}}.${LOCAL_DOMAIN}`)",
        "traefik.http.routers.{{RUNTIPI_APP_ID}}-local.entrypoints": "websecure",
        "traefik.http.routers.{{RUNTIPI_APP_ID}}-local.service": "{{RUNTIPI_APP_ID}}",
        "traefik.http.routers.{{RUNTIPI_APP_ID}}-local.tls": "true"
      }
    }
  ],
  "schemaVersion": 2,
  "$schema": "https://schemas.runtipi.io/v2/dynamic-compose.json"
}
